# Application Configuration
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
APP_NAME=Google Business Profile Manager
APP_VERSION=1.0.0
LOG_LEVEL=debug

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/gmb_db?schema=public"DB_HOST=localhost
DB_PORT=5432
DB_NAME=gbp_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_LOGGING=true

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRATION=7d
JWT_ALGORITHM=HS256

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/business.manage https://www.googleapis.com/auth/userinfo.email https://www.googleapis.com/auth/userinfo.profile

# Google Business Profile API Configuration
GOOGLE_API_KEY=your-google-api-key
GOOGLE_BUSINESS_ACCOUNT_ID=your-business-account-id
GOOGLE_API_RATE_LIMIT=600
GOOGLE_API_BATCH_SIZE=100
GOOGLE_SYNC_INTERVAL_MINUTES=60

# Stripe Configuration
STRIPE_PUBLIC_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_test_your_secret
STRIPE_WEBHOOK_URL=http://localhost:3000/api/webhooks/stripe

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=gbp-storage-dev
AWS_S3_CDN_URL=https://cdn.example.com
AWS_S3_PRESIGNED_URL_EXPIRY=3600

# SendGrid Configuration
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_FROM_NAME=Google Business Profile Manager

# SMTP Configuration (Optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_FROM_EMAIL=noreply@example.com

# Sentry Configuration
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0

# OpenTelemetry Configuration
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=gbp-platform
OTEL_SERVICE_VERSION=1.0.0

# Security Configuration
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
HELMET_ENABLED=true
CSRF_PROTECTION=true
XSS_PROTECTION=true
SESSION_SECRET=your-session-secret-change-in-production
SECURE_COOKIES=false
SAME_SITE_COOKIES=lax

# Feature Flags
FEATURE_GOOGLE_OAUTH_ENABLED=true
FEATURE_STRIPE_ENABLED=true
FEATURE_S3_ENABLED=true
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_AUDIT_LOGGING=true
FEATURE_ADVANCED_ANALYTICS=true

# Background Jobs Configuration
QUEUE_ENABLED=true
QUEUE_REMOVE_ON_COMPLETE=false
QUEUE_REMOVE_ON_FAIL=false
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=5000

# Kubernetes Configuration
ENVIRONMENT=development
REPLICA_COUNT=1
MEMORY_REQUEST=256Mi
MEMORY_LIMIT=512Mi
CPU_REQUEST=250m
CPU_LIMIT=500m

# Docker Configuration
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_TAG=latest

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Google Business Profile Manager
NEXT_PUBLIC_LOG_LEVEL=debug
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_your_key
NEXT_PUBLIC_ENVIRONMENT=development

# Development Configuration
DEBUG=gbp:*
VERBOSE_LOGGING=false
MOCK_GOOGLE_API=false
MOCK_STRIPE=false
DATABASE_SEED=true

# Staging Configuration (Override in .env.staging)
# STAGING_DATABASE_URL=postgresql://user:pass@staging-host:5432/gbp_staging
# STAGING_REDIS_URL=redis://staging-host:6379
# STAGING_ENVIRONMENT=staging

# Production Configuration (Override in .env.production)
# PRODUCTION_DATABASE_URL=postgresql://user:pass@prod-host:5432/gbp_prod
# PRODUCTION_REDIS_URL=redis://prod-host:6379
# PRODUCTION_ENVIRONMENT=production
# SECURE_COOKIES=true
# SAME_SITE_COOKIES=strict
